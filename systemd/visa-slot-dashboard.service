[Unit]
Description=Visa Slot Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/atlys-slot-watcher
Environment=DASHBOARD_PORT=8080
ExecStart=/usr/bin/python3 /opt/atlys-slot-watcher/dashboard.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
